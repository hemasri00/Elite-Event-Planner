# Flask Configuration
SECRET_KEY=replace_with_a_secure_random_string_here
FLASK_ENV=development
FLASK_APP=app.py

# Database Configuration (NeonDB PostgreSQL)
# Example: postgresql://neondb_owner:password@ep-cool-water-a5xyz.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Flask-Mail SMTP Configuration (Gmail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=your-gmail-app-specific-password
MAIL_DEFAULT_SENDER=your-gmail-address@gmail.com

# Admin Configuration
ADMIN_EMAIL=admin-receiver-email@gmail.com
